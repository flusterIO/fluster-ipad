{
    "$schema": "../../node_modules/turbo/schema.json",
    "extends": [
        "//"
    ],
    "tasks": {
        "build:website": {
            "dependsOn": [
                "^build:website"
            ],
            "outputs": [
                ".next/**",
                "!.next/cache/**"
            ]
        },
        "build:websiteCI": {
            "dependsOn": [
                "^build:websiteCI"
            ],
            "outputs": [
                ".next/**",
                "!.next/cache/**"
            ]
        },
        "typecheck": {
            "dependsOn": [
                "^typecheck"
            ]
        },
        "dev": {
            "persistent": true,
            "cache": false
        }
    }
}
