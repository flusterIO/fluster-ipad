{
    "$schema": "../../../node_modules/turbo/schema.json",
    "extends": [
        "//"
    ],
    "tags": [
        "webview"
    ],
    "tasks": {
        "build": {
            "inputs": [
                "./src/"
            ],
            "outputs": [
                "standalone_mdx_preview_ipad/",
                "standalone_mdx_preview_mac/"
            ],
            "passThroughEnv": [
                "FLUSTER_PROD_BUILD"
            ],
            "dependsOn": [
                "@fluster/webview_utils#build",
            ]
        },
        "build:ipad": {
            "inputs": [
                "./src/"
            ],
            "outputs": [
                "standalone_mdx_preview_ipad/"
            ],
            "passThroughEnv": [
                "FLUSTER_PROD_BUILD"
            ],
            "dependsOn": [
                "@fluster/webview_utils#build",
            ]
        },
        "build:mac": {
            "inputs": [
                "./src/"
            ],
            "outputs": [
                "standalone_mdx_preview_mac/"
            ],
            "passThroughEnv": [
                "FLUSTER_PROD_BUILD"
            ],
            "dependsOn": [
                "@fluster/webview_utils#build",
            ]
        }
    }
}
