{
    "name": "@fluster/wasm",
    "scripts": {
        "build": "wireit",
        "dev": "webpack serve"
    },
    "wireit": {
        "build": {
            "command": "webpack"
        }
    },
    "exports": {
        ".": {
            "require": "./pkg/index.js",
            "import": "./pkg/index.js",
            "types": "./pkg/index.d.ts"
        },
        "./fluster": {
            "require": "./pkg/fluster_wasm.js",
            "import": "./pkg/fluster_wasm.js",
            "types": "./pkg/fluster_wasm.d.ts"
        }
    },
    "devDependencies": {
        "@types/webpack": "^5.28.5",
        "@types/webpack-dev-server": "^4.7.2",
        "@wasm-tool/wasm-pack-plugin": "1.7.0",
        "html-webpack-plugin": "5.6.6",
        "ts-node": "^10.9.2",
        "webpack": "5.105.4",
        "webpack-cli": "6.0.1",
        "webpack-dev-server": "5.2.3"
    }
}
