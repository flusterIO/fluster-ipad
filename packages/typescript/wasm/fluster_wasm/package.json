{
  "name": "@fluster/wasm",
  "type": "module",
  "scripts": {
    "build": "wireit",
    "dev": "webpack serve"
  },
  "wireit": {
    "build": {
      "command": "RUSTFLAGS=\"-C target-feature=+bulk-memory\" wasm-pack build --target web ./ && webpack"
    }
  },
  "exports": {
    ".": {
      "types": "./pkg/index.js",
      "import": "./pkg/index.js",
      "require": "./pkg/index.js"
    },
    "./fluster": {
      "types": "./pkg/fluster_wasm.d.ts",
      "import": "./pkg/fluster_wasm.js",
      "require": "./pkg/fluster_wasm.js"
    }
  },
  "devDependencies": {
    "@types/webpack": "5.28.5",
    "@types/webpack-dev-server": "4.7.2",
    "@wasm-tool/wasm-pack-plugin": "1.7.0",
    "html-webpack-plugin": "5.6.6",
    "ts-node": "10.9.2",
    "webpack": "5.105.4",
    "webpack-cli": "6.0.1",
    "webpack-dev-server": "5.2.3"
  }
}
