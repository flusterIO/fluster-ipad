{
    "compilerOptions": {
        "baseUrl": ".",
        "inlineSourceMap": true,
        "inlineSources": true,
        "module": "ESNext",
        "strictNullChecks": true,
        "target": "ESNext",
        "allowJs": true,
        "noImplicitAny": true,
        "moduleResolution": "bundler",
        "importHelpers": true,
        "lib": [
            "dom",
            "ESNext"
        ],
        "esModuleInterop": true,
        "rootDir": "src"
    },
    "include": [
        "src"
    ],
    "exclude": [
        "vite.config.ts"
    ]
}
