{
    "$schema": "../../../node_modules/turbo/schema.json",
    "extends": [
        "//"
    ],
    "tasks": {
        "build": {
            "inputs": [
                "./src/"
            ],
            "outputs": [
                "./dist/"
            ]
        },
        "build:website": {
            "dependsOn": [
                "build"
            ]
        },
        "build:websiteCI": {
            "dependsOn": [
                "build:website"
            ]
        },
        "typecheck": {
            "dependsOn": [
                "^typecheck"
            ]
        }
    }
}
