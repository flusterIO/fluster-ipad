{
    "$schema": "../../../node_modules/turbo/schema.json",
    "extends": [
        "//"
    ],
    "tasks": {
        "docgen:writeComponentList": {
            "dependsOn": [
                "docgen:gatherComponentDocs"
            ]
        },
        "docgen:copyDocumentationToRust": {
            "dependsOn": [
                "docgen:main"
            ]
        },
        "docgen:internalDiagrams": {},
        "docgen:gatherComponentDocs": {},
        "docgen:buildCrossLanguage": {},
        "docgen:main": {
            "inputs": [
                "./src/*",
                "./templates/*"
            ],
            "with": [
                "docgen:internalDiagrams"
            ],
            "dependsOn": [
                "docgen:buildCrossLanguage",
                "docgen:gatherComponentDocs",
                "docgen:writeComponentList"
            ]
        },
        "docgen:cleanupGeneratedTypes": {
            "dependsOn": [
                "docgen:main"
            ]
        },
        "docgen": {
            "dependsOn": [
                "docgen:main",
                "docgen:copyDocumentationToRust",
                "docgen:cleanupGeneratedTypes"
            ]
        }
    }
}
