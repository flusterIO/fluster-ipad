{
  "name": "conundrum-web-components",
  "version": "0.0.1",
  "description": "Stencil Component Starter",
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build",
    "generate": "stencil generate",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil-test --prod",
    "test:watch": "stencil-test --prod --watch"
  },
  "types": "dist/types/index.d.ts",
  "main": "dist/index.cjs.js",
  "exports": {
    ".": {
      "import": "./dist/conundrum-web-components/conundrum-web-components.esm.js",
      "require": "./dist/conundrum-web-components/conundrum-web-components.cjs.js"
    },
    "./my-component": {
      "types": "./dist/components/my-component.d.ts",
      "import": "./dist/components/my-component.js"
    },
    "./loader": {
      "types": "./loader/index.d.ts",
      "import": "./loader/index.js",
      "require": "./loader/index.cjs"
    }
  },
  "devDependencies": {
    "@stencil/core": "^4.27.1 || ^5.0.0-0",
    "@stencil/vitest": "1.8.3",
    "@types/node": "24.10.1",
    "@vitest/browser-playwright": "4.0.0",
    "playwright": "1.52.0",
    "vitest": "4.0.18"
  },
  "packageManager": "pnpm@10.30.3",
  "license": "MIT",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "module": "dist/index.js",
  "repository": "stenciljs/component-starter.git",
  "unpkg": "dist/conundrum-web-components/conundrum-web-components.esm.js"
}
