      "require": "./dist/methods.cjs.js"
    }
  },
  "dependencies": {
    "@conundrum/generated": "workspace:*",
    "@fluster/wasm": "workspace:*",
    "@reduxjs/toolkit": "2.8.2",
    "consola": "3.4.2",
    "react-redux": "9.2.0",
    "stencil": "^0.0.5"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.2.1",
    "typescript": "latest",
    "vite-plugin-dts": "4.5.4",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.0.18"
  },
  "packageManager": "pnpm@10.30.3"
