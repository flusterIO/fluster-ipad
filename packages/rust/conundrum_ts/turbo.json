{
    "$schema": "../../../node_modules/turbo/schema.json",
    "extends": [
        "//"
    ],
    "tags": [
        "conundrum"
    ],
    "tasks": {
        "copy:globalCSS": {
            "inputs": [
                "../conundrum/src/output/html/standalone/conundrum.css"
            ],
            "outputs": [
                "./dist/styles.css"
            ],
            "dependsOn": [
                "@conundrum/main#build:scss"
            ]
        },
        "build:vite": {
            "outputs": [
                "dist/",
                "!dist/styles.css"
            ],
            "inputs": [
                "./src/",
                "../conundrum/**/*.rs"
            ]
        },
        "build": {
            "outputs": [
                "./dist/"
            ],
            "inputs": [
                "./src/"
            ],
            "dependsOn": [
                "copy:globalCSS",
                "build:vite"
            ]
        },
        "build:website": {
            "dependsOn": [
                "build"
            ]
        },
        "build:websiteCI": {
            "dependsOn": [
                "build:website"
            ]
        }
    }
}
