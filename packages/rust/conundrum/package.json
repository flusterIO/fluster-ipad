{
  "name": "@conundrum/main",
  "version": "0.0.1",
  "description": "Don't use this directly, use the packages that depend on this like @conundrum/ts & @conundrum/wasm to setup your environment for Conundrum content.",
  "keywords": [
    "academic",
    "fluster",
    "note taking",
    "science",
    "STEM"
  ],
  "funding": [
    {
      "type": "paypal",
      "url": "https://www.paypal.com/ncp/payment/D6S6NP4AHJD6Y"
    },
    {
      "type": "patreon",
      "url": "https://www.patreon.com/uhlittlelessdum/about"
    },
    {
      "type": "github",
      "url": "https://github.com/flusterIO/fluster"
    }
  ],
  "type": "module",
  "private": true,
  "files": [
    "src/output/html/standalone/conundrum.css"
  ],
  "scripts": {
    "build:rust": "cargo build --package conundrum",
    "build:scss": "../../../node_modules/@tailwindcss/cli/dist/index.mjs --input ./src/output/html/standalone/conundrum_input.scss --output ./src/output/html/standalone/conundrum.css",
    "build:ts": "wireit",
    "build:tsProd": "wireit",
    "copy:katexcss": "cp ../../../node_modules/katex/dist/katex.min.css ./src/output/html/glue/component_glue/other/katex.min.css",
    "copy:scss_input": "cp ./src/output/html/standalone/conundrum_input.scss ../conundrum_web_assets/src/css/conundrum_input.scss",
    "test": "zsh ./current_test.zsh"
  },
  "wireit": {
    "build:tabs": {
      "command": "vite build",
      "env": {
        "CDRM_COMPONENT_NAME": "TABS"
      }
    },
    "build:footnotes": {
      "command": "vite build",
      "env": {
        "CDRM_COMPONENT_NAME": "FOOTNOTES"
      }
    },
    "build:admonition": {
      "command": "vite build",
      "env": {
        "CDRM_COMPONENT_NAME": "ADMONITION"
      }
    },
    "build:code_block": {
      "command": "vite build",
      "env": {
        "CDRM_COMPONENT_NAME": "CODE_BLOCK"
      }
    },
    "build:toc": {
      "command": "vite build",
      "env": {
        "CDRM_COMPONENT_NAME": "TOC"
      }
    },
    "build:note_link": {
      "command": "vite build",
      "env": {
        "CDRM_COMPONENT_NAME": "NOTE_LINK"
      }
    },
    "build:tabs_prod": {
      "command": "vite build",
      "env": {
        "CDRM_COMPONENT_NAME": "TABS",
        "FLUSTER_PROD_BUILD": "true"
      }
    },
    "build:footnotes_prod": {
      "command": "vite build",
      "env": {
        "CDRM_COMPONENT_NAME": "FOOTNOTES",
        "FLUSTER_PROD_BUILD": "true"
      }
    },
    "build:admonition_prod": {
      "command": "vite build",
      "env": {
        "CDRM_COMPONENT_NAME": "ADMONITION",
        "FLUSTER_PROD_BUILD": "true"
      }
    },
    "build:code_block_prod": {
      "command": "vite build",
      "env": {
        "CDRM_COMPONENT_NAME": "CODE_BLOCK",
        "FLUSTER_PROD_BUILD": "true"
      }
    },
    "build:toc_prod": {
      "command": "vite build",
      "env": {
        "CDRM_COMPONENT_NAME": "TOC",
        "FLUSTER_PROD_BUILD": "true"
      }
    },
    "build:note_link_prod": {
      "command": "vite build",
      "env": {
        "CDRM_COMPONENT_NAME": "NOTE_LINK",
        "FLUSTER_PROD_BUILD": "true"
      }
    },
    "build:ts": {
      "dependencies": [
        "build:tabs",
        "build:admonition",
        "build:code_block",
        "build:note_link",
        "build:toc",
        "build:footnotes"
      ]
    },
    "build:tsProd": {
      "dependencies": [
        "build:tabs_prod",
        "build:admonition_prod",
        "build:code_block_prod",
        "build:note_link_prod",
        "build:toc_prod",
        "build:footnotes_prod"
      ]
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.umd.js",
  "exports": {
    "./conundrum.css": {
      "import": "./src/output/html/standalone/conundrum.css",
      "require": "./src/output/html/standalone/conundrum.css"
    }
  },
  "dependencies": {
    "@conundrum/ts": "workspace:*",
    "@tailwindcss/container-queries": "0.1.1",
    "@tailwindcss/postcss": "4.1.10",
    "motion": "12.39.0",
    "tailwind-merge": "3.3.0",
    "tailwindcss": "4.2.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.19",
    "@tailwindcss/vite": "4.2.1"
  },
  "prettier": "../../shared_config/prettier.config.ts",
  "packageManager": "pnpm@9.7.1",
  "license": "MIT"
}
