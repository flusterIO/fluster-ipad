<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% if let Some(l) = label %}{{l}}{% else %}Conundrum{% endif %}</title>
    <style>
        {{css | safe}}
    </style>
</head>

<body data-cdrm-theme="cdrm" {% if ui.dark_mode %}class="dark"{% else %}class=""{% endif %}>
    <div id="content" class="@container/mdx cdrm-container w-full px-4 py-6 min-h-screen mx-auto prose {% if ui.dark_mode %}prose-invert{% endif %} max-w-[min(1080px,100vw)]">
        {{body | safe}}
    </div>
</body>
<script>
    {{js | safe}}
</script>
</html>
