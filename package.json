{
  "name": "fluster.io",
  "description": "Advanced note taking for the modern academic.",
  "funding": [
    {
      "type": "paypal",
      "url": "https://www.paypal.com/ncp/payment/D6S6NP4AHJD6Y"
    },
    {
      "type": "patreon",
      "url": "https://www.patreon.com/uhlittlelessdum/about"
    },
    {
      "type": "github",
      "url": "https://github.com/flusterIO/fluster"
    }
  ],
  "scripts": {
    "build:macStep2": "wireit",
    "build:postCodegenCleanup": "tsx ./scripts/post_cross_language_modifications.ts",
    "build:webviewsMac": "wireit",
    "build:webviewsMacProd": "wireit",
    "commit": "builtin command cat ./commit.md | aicommits -p",
    "prepare": "husky"
  },
  "wireit": {
    "build:webviewsMac": {
      "dependencies": [
        "./packages/webviews/splitview_mdx_editor:build:mac",
        "./packages/webviews/note_detail_webview:build:mac",
        "./packages/webviews/standalone_mdx_preview:build:mac",
        "./packages/webviews/bibtex_editor_webview:build:mac",
        "./packages/webviews/dictionary_webview:build:mac"
      ]
    },
    "build:webviewsMacProd": {
      "dependencies": [
        "./packages/webviews/splitview_mdx_editor:build:macProd",
        "./packages/webviews/note_detail_webview:build:macProd",
        "./packages/webviews/standalone_mdx_preview:build:macProd",
        "./packages/webviews/bibtex_editor_webview:build:macProd",
        "./packages/webviews/dictionary_webview:build:macProd"
      ]
    },
    "build:macStep2": {
      "dependencies": [
        "./packages/rust/conundrum_ts:build:mac",
        "./packages/rust/wasm/conundrum_wasm:build",
        "./packages/typescript/codemirror-lang-bib:build:parser"
      ]
    },
    "build:macStep2Prod": {
      "dependencies": [
        "./packages/rust/conundrum_ts:build:macProd",
        "./packages/rust/wasm/conundrum_wasm:buildProd",
        "./packages/typescript/codemirror-lang-bib:build:parser"
      ]
    }
  },
  "dependencies": {
    "shiki": "3.3.0"
  },
  "devDependencies": {
    "@codspeed/vitest-plugin": "5.2.0",
    "@eslint/js": "9.39.1",
    "@evankirkiles/vite-plugin-wasm-pack": "0.1.14",
    "@faker-js/faker": "10.3.0",
    "@mermaid-js/mermaid-cli": "11.12.0",
    "@next/eslint-plugin-next": "16.1.1",
    "@tailwindcss/cli": "4.1.17",
    "@types/eslint": "9.6.1",
    "@types/mdx": "2.0.13",
    "@types/node": "24.10.1",
    "@types/react": "19.2.2",
    "@vitejs/plugin-react": "5.1.1",
    "@welldone-software/why-did-you-render": "10.0.1",
    "autoprefixer": "10.4.21",
    "babel-plugin-react-compiler": "1.0.0",
    "consola": "3.4.2",
    "eslint": "9.39.1",
    "eslint-config-next": "15.3.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "husky": "9.1.7",
    "ignorepatterns": "5.6.0",
    "jiti": "2.6.1",
    "markdown-table": "3.0.4",
    "postcss": "8.5.3",
    "prettier": "3.7.4",
    "prettier-plugin-tailwindcss": "0.7.2",
    "quicktype": "23.2.6",
    "quicktype-core": "23.2.6",
    "syncpack": "13.0.4",
    "tailwindcss": "4.2.1",
    "tsx": "4.20.6",
    "turbo": "2.9.16",
    "typescript": "*",
    "typescript-eslint": "8.46.4",
    "vite": "7.2.4",
    "vite-plugin-html-minifier": "1.0.5",
    "vite-plugin-singlefile": "2.3.0",
    "vite-plugin-top-level-await": "1.6.0",
